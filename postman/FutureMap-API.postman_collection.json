{
  "info": {
    "name": "FutureMap API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Budi Mahasiswa\",\n    \"email\": \"budi@student.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"mahasiswa\",\n    \"nim\": \"2021001\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/register",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "register"]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"budi@student.com\",\n    \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "login"]
            }
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/user",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "user"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?page=1&per_page=10&sort=latest",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                },
                {
                  "key": "sort",
                  "value": "latest"
                }
              ]
            }
          }
        },
        {
          "name": "Get Jobs with Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/jobs?type=fulltime&work_style=remote&min_salary=5000000&sort=salary_high",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs"],
              "query": [
                {
                  "key": "type",
                  "value": "fulltime"
                },
                {
                  "key": "work_style",
                  "value": "remote"
                },
                {
                  "key": "min_salary",
                  "value": "5000000"
                },
                {
                  "key": "sort",
                  "value": "salary_high"
                }
              ]
            }
          }
        },
        {
          "name": "Get Job Detail",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/1",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "1"]
            }
          }
        },
        {
          "name": "Apply for Job",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "cv",
                  "type": "file",
                  "src": "/path/to/cv.pdf"
                },
                {
                  "key": "cover_letter",
                  "value": "Saya sangat tertarik dengan posisi ini karena..."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/1/apply",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "1", "apply"]
            }
          }
        },
        {
          "name": "Get Job Recommendations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/jobs/recommendations",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "jobs", "recommendations"]
            }
          }
        }
      ]
    },
